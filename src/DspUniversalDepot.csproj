<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AssemblyName>DspUniversalDepot</AssemblyName>
    <RootNamespace>DspUniversalDepot</RootNamespace>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <Description>A universal planetary depot with configurable item limits and dynamic slot allocation.</Description>
    <Authors>boehla</Authors>
    <Version>0.2.2</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <NoWarn>CS0414;CS0169;CS0649;CS0067;CS0117;CS0029;CS0019;CS1503;CS0118;CS0234;CS0103;CS0021;CS0436</NoWarn>
  </PropertyGroup>

  <!--
    ============================================================
    BUILD MODES
    ============================================================

    Mode 1: Real DSP DLLs (RECOMMENDED, works on Linux/Windows)
    =====
      dotnet build -c Release
      Uses the ./libs/ folder (auto-downloaded from NuGet +
      GitHub DSP-Mods repo). Compiles against real BepInEx 5.4,
      Harmony, UnityEngine, CommonAPI, LDBTool, NebulaAPI,
      DSPModSave, and AsmResolver.
      The resulting DLL WILL load in DSP.

    Mode 2: Real DSP install (Windows + DSP installed)
    =====
      set DSP_GAME_PATH="C:\Program Files (x86)\Steam\steamapps\common\Dyson Sphere Program"
      dotnet build -c Release
      Uses DLLs from your live DSP install, guaranteed exact version
      match (DSP updates can change the Unity engine version, so this
      is the safest mode for production use).

    Mode 3: Stubs (CI / no DSP / no internet)
    =====
      dotnet build -c Release -p:DSP_USE_STUBS=true
      OR: rm -rf ../libs && dotnet build
      BepInEx/Harmony/Unity/DSP types are stubbed. The DLL
      COMPILES but WILL NOT load in DSP, useful only for
      compile-time validation in sandboxes.
  -->

  <PropertyGroup Condition="'$(DSP_USE_STUBS)' == 'true'">
    <DefineConstants>$(DefineConstants);HAS_DSP_REFS</DefineConstants>
  </PropertyGroup>

  <!-- Reference real DSP DLLs from ./libs/ if present -->
  <ItemGroup Condition="Exists('../libs/') And '$(DSP_USE_STUBS)' != 'true'">
    <Reference Include="BepInEx">
      <HintPath>../libs/BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx.Harmony">
      <HintPath>../libs/BepInEx.Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="BepInEx.Preloader">
      <HintPath>../libs/BepInEx.Preloader.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>../libs/0Harmony.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>../libs/UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>../libs/UnityEngine.CoreModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.IMGUIModule">
      <HintPath>../libs/UnityEngine.IMGUIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UI">
      <HintPath>../libs/UnityEngine.UIModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine.UI.Builder">
      <HintPath>../libs/UnityEngine.UIElementsModule.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="CommonAPI">
      <HintPath>../libs/CommonAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="LDBTool">
      <HintPath>../libs/LDBTool.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="NebulaAPI">
      <HintPath>../libs/NebulaAPI.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="DSPModSave">
      <HintPath>../libs/DSPModSave.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <!--
    If DSP_GAME_PATH is set, use DLLs directly from the DSP install.
    This guarantees version match.
  -->
  <ItemGroup Condition="'$(DSP_GAME_PATH)' != '' And '$(DSP_USE_STUBS)' != 'true'">
    <Reference Include="BepInEx">
      <HintPath>$(DSP_GAME_PATH)BepInEx\core\BepInEx.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="UnityEngine">
      <HintPath>$(DSP_GAME_PATH)Dyson Sphere Program_Data\Managed\UnityEngine.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(DSP_GAME_PATH)Dyson Sphere Program_Data\Managed\Assembly-CSharp.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <PropertyGroup Condition="'$(DSP_GAME_PATH)' != ''">
    <DefineConstants>$(DefineConstants);HAS_DSP_REFS</DefineConstants>
  </PropertyGroup>
</Project>
