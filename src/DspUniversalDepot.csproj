<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net6.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <AssemblyName>DspUniversalDepot</AssemblyName>
    <RootNamespace>DspUniversalDepot</RootNamespace>
    <GenerateAssemblyInfo>true</GenerateAssemblyInfo>
    <CopyLocalLockFileAssemblies>false</CopyLocalLockFileAssemblies>
    <Description>A universal planetary depot with configurable item limits and dynamic slot allocation.</Description>
    <Authors>boehla</Authors>
    <Version>0.1.0</Version>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <Reference Include="UnityEngine">
      <HintPath>$(DSP_GAME_PATH)/DSPGAME_Data/Managed/UnityEngine.dll</HintPath>
    </Reference>
    <Reference Include="UnityEngine.CoreModule">
      <HintPath>$(DSP_GAME_PATH)/DSPGAME_Data/Managed/UnityEngine.CoreModule.dll</HintPath>
    </Reference>
    <Reference Include="Assembly-CSharp">
      <HintPath>$(DSP_GAME_PATH)/DSPGAME_Data/Managed/Assembly-CSharp.dll</HintPath>
    </Reference>
    <Reference Include="0Harmony">
      <HintPath>$(DSP_GAME_PATH)/BepInEx/core/0Harmony.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx.Core">
      <HintPath>$(DSP_GAME_PATH)/BepInEx/core/BepInEx.Core.dll</HintPath>
    </Reference>
    <Reference Include="BepInEx.Unity.IL2CPP">
      <HintPath>$(DSP_GAME_PATH)/BepInEx/core/BepInEx.Unity.IL2CPP.dll</HintPath>
    </Reference>
  </ItemGroup>

  <PropertyGroup>
    <DSP_GAME_PATH Condition="'$(DSP_GAME_PATH)' == ''">C:\Program Files (x86)\Steam\steamapps\common\Dyson Sphere Program</DSP_GAME_PATH>
  </PropertyGroup>
</Project>
